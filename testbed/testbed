#!/bin/bash
# Testbed CLI - manage Docker-based payload testing stacks
#
# Usage:
#   ./testbed up <stack>              Start a testbed stack (+ OOB catcher)
#   ./testbed down <stack>            Stop a testbed stack
#   ./testbed run <stack> [wordlist]  Start stack, run payloads, stop stack
#   ./testbed logs <stack>            Tail logs for a stack
#   ./testbed oob                     Show OOB callbacks received
#   ./testbed clear                   Clear OOB callback log
#   ./testbed list                    List available stacks
#   ./testbed status                  Show running containers
#   ./testbed nuke                    Stop everything, prune Docker

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STACKS_DIR="$SCRIPT_DIR/stacks"
OOB_COMPOSE="$SCRIPT_DIR/docker-compose.oob.yml"
RUNNER="$SCRIPT_DIR/runner.py"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

ensure_oob() {
    if ! docker compose -f "$OOB_COMPOSE" ps --status running 2>/dev/null | grep -q oob; then
        echo -e "${CYAN}[*] Starting OOB callback catcher...${NC}"
        docker compose -f "$OOB_COMPOSE" up -d --build
        sleep 2
    fi
}

get_compose_file() {
    local stack="$1"
    local compose="$STACKS_DIR/$stack/docker-compose.yml"
    if [ ! -f "$compose" ]; then
        echo -e "${RED}[!] Stack not found: $stack${NC}" >&2
        echo -e "    Run './testbed list' to see available stacks" >&2
        exit 1
    fi
    echo "$compose"
}

case "${1:-help}" in
    up)
        [ -z "$2" ] && echo "Usage: ./testbed up <stack>" && exit 1
        compose=$(get_compose_file "$2")
        ensure_oob
        echo -e "${GREEN}[+] Starting stack: $2${NC}"
        docker compose -f "$compose" up -d --build
        echo -e "${GREEN}[+] Stack $2 is running${NC}"
        docker compose -f "$compose" ps
        ;;

    down)
        [ -z "$2" ] && echo "Usage: ./testbed down <stack>" && exit 1
        compose=$(get_compose_file "$2")
        echo -e "${YELLOW}[-] Stopping stack: $2${NC}"
        docker compose -f "$compose" down
        ;;

    run)
        [ -z "$2" ] && echo "Usage: ./testbed run <stack> [wordlist]" && exit 1
        compose=$(get_compose_file "$2")
        wordlist="${3:-$PROJECT_ROOT/payloads/full.txt}"
        if [ ! -f "$wordlist" ]; then
            wordlist="${3:-$PROJECT_ROOT/polyglots.txt}"
        fi

        ensure_oob
        echo -e "${GREEN}[+] Starting stack: $2${NC}"
        docker compose -f "$compose" up -d --build
        echo -e "${CYAN}[*] Waiting for services to be healthy...${NC}"
        sleep 3

        echo -e "${CYAN}[*] Running payloads from: $wordlist${NC}"
        python3 "$RUNNER" --stack "$2" --wordlist "$wordlist" --config "$SCRIPT_DIR/runner-config.yml"

        echo -e "${YELLOW}[-] Stopping stack: $2${NC}"
        docker compose -f "$compose" down
        ;;

    logs)
        [ -z "$2" ] && echo "Usage: ./testbed logs <stack>" && exit 1
        compose=$(get_compose_file "$2")
        docker compose -f "$compose" logs -f
        ;;

    oob)
        curl -s http://localhost:9999/callbacks 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "OOB catcher not running. Start with: ./testbed up <any-stack>"
        ;;

    clear)
        curl -s -X POST http://localhost:9999/clear 2>/dev/null && echo "Callbacks cleared" || echo "OOB catcher not running"
        ;;

    list)
        echo -e "${CYAN}Available stacks:${NC}"
        for d in "$STACKS_DIR"/*/; do
            if [ -f "$d/docker-compose.yml" ]; then
                stack=$(basename "$d")
                echo "  $stack"
            fi
        done
        ;;

    status)
        echo -e "${CYAN}Running containers:${NC}"
        docker ps --filter "network=testbed-net" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
        ;;

    nuke)
        echo -e "${RED}[!] Stopping all testbed containers...${NC}"
        docker compose -f "$OOB_COMPOSE" down 2>/dev/null || true
        for d in "$STACKS_DIR"/*/; do
            if [ -f "$d/docker-compose.yml" ]; then
                docker compose -f "$d/docker-compose.yml" down 2>/dev/null || true
            fi
        done
        echo -e "${YELLOW}[*] Pruning unused Docker resources...${NC}"
        docker system prune -f
        echo -e "${GREEN}[+] Clean${NC}"
        ;;

    help|--help|-h|*)
        echo "Testbed CLI - manage Docker-based payload testing stacks"
        echo ""
        echo "Usage:"
        echo "  ./testbed up <stack>              Start a testbed stack"
        echo "  ./testbed down <stack>            Stop a testbed stack"
        echo "  ./testbed run <stack> [wordlist]  Run payloads against a stack"
        echo "  ./testbed logs <stack>            Tail logs for a stack"
        echo "  ./testbed oob                     Show OOB callbacks"
        echo "  ./testbed clear                   Clear OOB callback log"
        echo "  ./testbed list                    List available stacks"
        echo "  ./testbed status                  Show running containers"
        echo "  ./testbed nuke                    Stop everything, prune Docker"
        ;;
esac
